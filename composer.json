{
  "name": "surfnet/stepup-webauthn",
  "license": "Apache-2.0",
  "description": "WebAuthn Generic SAML Stepup Provider.",
  "type": "project",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Surfnet\\Webauthn\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Dev\\": "dev",
      "Test\\": "tests"
    }
  },
  "require": {
    "php": "8.2.*",
    "ext-dom": "*",
    "ext-gmp": "*",
    "ext-json": "*",
    "ext-libxml": "*",
    "ext-zlib": "*",
    "doctrine/common": "^3.4",
    "doctrine/doctrine-bundle": "^2.11",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "doctrine/orm": "^2.20",
    "incenteev/composer-parameter-handler": "^v2.1",
    "nyholm/psr7": "^1.8",
    "openconext/monitor-bundle": "^4.0",
    "ramsey/uuid": "^4.7",
    "spomky-labs/cbor-bundle": "^3.0 || ^4.0@dev",
    "spomky-labs/cbor-php": "^3.1",
    "surfnet/stepup-bundle": "^6.0 || ^7.0",
    "surfnet/stepup-gssp-bundle": "^5.0 || ^6.0",
    "surfnet/stepup-saml-bundle": "^6.0 || ^7.0",
    "symfony/asset": "7.4.*",
    "symfony/cache": "7.4.*",
    "symfony/config": "7.4.*",
    "symfony/console": "7.4.*",
    "symfony/flex": "^2.4",
    "symfony/form": "7.4.*",
    "symfony/http-client": "7.4.*",
    "symfony/monolog-bundle": "^3.8 || ^4.0",
    "symfony/runtime": "7.4.*",
    "symfony/security-bundle": "7.4.*",
    "symfony/stimulus-bundle": "^2.15",
    "symfony/translation": "7.4.*",
    "symfony/twig-bundle": "7.4.*",
    "symfony/validator": "7.4.*",
    "symfony/webpack-encore-bundle": "^2.1",
    "symfony/yaml": "7.4.*",
    "twig/twig": "^3.8",
    "web-auth/cose-lib": "^4.4",
    "web-auth/webauthn-lib": "^5.2",
    "web-auth/webauthn-stimulus": "^5.2",
    "web-auth/webauthn-symfony-bundle": "^5.2",
    "web-token/jwt-library": "^4.1"
  },
  "require-dev": {
    "malukenho/docheader": "^1",
    "mockery/mockery": "^1.6",
    "overtrue/phplint": "*",
    "phpmd/phpmd": "^2.14",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-symfony": "^2.0",
    "phpunit/phpunit": "^11.5",
    "rector/rector": "^2.2",
    "slevomat/coding-standard": "^8.27",
    "squizlabs/php_codesniffer": "^4.0",
    "symfony/browser-kit": "7.4.*",
    "symfony/css-selector": "7.4.*",
    "symfony/phpunit-bridge": "7.4.*",
    "symfony/stopwatch": "7.4.*",
    "symfony/web-profiler-bundle": "7.4.*"
  },
  "scripts": {
    "check": [
      "@composer-validate",
      "@docheader",
      "@lint",
      "@phpcs",
      "@phpmd",
      "@phpstan",
      "@unit-tests",
      "@doctrine-schema-validate"
    ],
    "composer-validate": "./ci/qa/validate",
    "docheader": "./ci/qa/docheader",
    "lint": "./ci/qa/lint",
    "phpcs": "./ci/qa/phpcs",
    "phpcbf": "./ci/qa/phpcbf",
    "phpmd": "./ci/qa/phpmd",
    "phpstan": "./ci/qa/phpstan",
    "phpstan-baseline": "./ci/qa/phpstan-update-baseline",
    "rector": "./ci/qa/rector.sh --dry-run",
    "rector-fix": "./ci/qa/rector.sh",
    "unit-tests": "ci/qa/phpunit",
    "doctrine-schema-validate": "ci/qa/doctrine-schema-validate",
    "frontend-install": [
      "yarn install"
    ],
    "encore": [
      "./node_modules/.bin/encore"
    ],
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install": "symfony-cmd"
    },
    "post-install-cmd": [
      "Incenteev\\ParameterHandler\\ScriptHandler::buildParameters",
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "Incenteev\\ParameterHandler\\ScriptHandler::buildParameters",
      "@auto-scripts"
    ]
  },
  "archive": {
    "exclude": [
      "!/.env",
      "!/.env.local.php",
      "!/var/cache/prod",
      "!/public/build",
      ".github",
      ".gitignore",
      "/symfony.lock",
      "/node_modules",
      "/assets",
      "/ci",
      "/dev",
      "/translations/sp",
      "tests",
      "/build",
      "/tsconfig.json",
      "/tslint.json",
      "/Vagrantfile",
      "/webpack.config.js",
      "/.docheader",
      "/.env.ci",
      "/.env.test",
      "/.env.vm",
      "/*.xml",
      "/*.xml.dist",
      "/config/routes/dev",
      "/config/packages/dev",
      "/config/packages/test",
      "/node_modules",
      "/build",
      "/docker"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.2"
    },
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "endroid/installer": false
    },
    "audit": {
      "block-insecure": false
    }
  },
  "extra": {
    "runtime": {
      "disable_dotenv": true
    },
    "symfony": {
      "allow-contrib": false,
      "require": "7.4.*"
    },
    "incenteev-parameters": [
      {
        "file": "config/openconext/parameters.yaml"
      }
    ]
  }
}
